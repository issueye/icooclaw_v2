{
  "name": "iclang-vscode",
  "displayName": "iclang",
  "description": "Syntax highlighting and editor support for icooclaw script language.",
  "version": "0.1.0",
  "publisher": "issueye",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/issueye/icooclaw_v2.git"
  },
  "homepage": "https://github.com/issueye/icooclaw_v2/tree/main/icooclaw_lang/vscode-extension",
  "bugs": {
    "url": "https://github.com/issueye/icooclaw_v2/issues"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "iclang",
    "icooclaw",
    "syntax",
    "highlighting"
  ],
  "scripts": {
    "package": "vsce package",
    "package:out": "vsce package -o iclang-vscode.vsix"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.6.2"
  },
  "contributes": {
    "languages": [
      {
        "id": "iclang",
        "aliases": [
          "iclang",
          "Icooclaw Script"
        ],
        "extensions": [
          ".is"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "iclang",
        "scopeName": "source.iclang",
        "path": "./syntaxes/iclang.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "iclang",
        "path": "./snippets/iclang.code-snippets"
      }
    ]
  }
}
