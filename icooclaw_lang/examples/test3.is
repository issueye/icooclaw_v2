# Test nested if
a = 5
if a > 10 {
    print("a > 10")
} else {
    if a > 3 {
        print("a > 3")
    } else {
        print("a <= 3")
    }
}

# Test while with if inside
b = 0
while b < 3 {
    b = b + 1
    if b == 2 {
        print("b is 2")
    }
}

# Test if without else
c = 10
if c > 5 {
    print("c is big")
}
