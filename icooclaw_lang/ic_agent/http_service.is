import "./modules/http_api.is" as api

app_root = path.dir(os.script_path())
pkg = toml.parse_file(path.join(app_root, "pkg.toml"))
default_addr = os.flag_or("addr", str(pkg.service.addr))

server = http.server.new()
http_server = api.new_http_server(pkg)

server.route_file("GET", "/", path.join(app_root, "web", "index.html"), "text/html; charset=utf-8")
server.handle("GET", "/health", http_server.health_handler)
server.handle("GET", "/tools", http_server.tools_handler)
server.handle("POST", "/chat", http_server.chat_handler)
server.not_found({
    "status_code": 404,
    "body": json.stringify({
        "ok": false,
        "error": "not found",
    }),
    "headers": {
        "Content-Type": "application/json",
    },
})

listen_addr = server.start(default_addr)

print(str(pkg.name) + " http service")
print("version: " + str(pkg.version))
print("addr: " + listen_addr)
print("ui: " + server.url("/"))
print("health: " + server.url("/health"))
print("tools: " + server.url("/tools"))
print("chat: " + server.url("/chat"))

while true {
    time.sleep(3600)
}
